# RoadSense — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git

# Server
PORT=5000
DEBUG=false

# CORS — set to your dashboard's actual domain in production
ALLOWED_ORIGINS=http://localhost:5000,https://yourdashboard.example.com

# Database
DB_PATH=roadsense.db
IMAGE_DIR=static/detections

# API Keys  (format: key:role,key:role)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=your-device-key-here:device,your-dashboard-key-here:dashboard,your-admin-key-here:admin

# Rate limits (requests per minute per key)
DEVICE_RATE_LIMIT=120
DASHBOARD_RATE_LIMIT=120
